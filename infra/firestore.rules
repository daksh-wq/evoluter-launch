rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── HELPER FUNCTIONS ───────────────────────────────
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user accessing data is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user has a specific role claim (if using Custom Claims)
    // Or check against a user profile field (less secure but common)
    function hasRole(role) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Standard timestamp validation for "createdAt" and "updatedAt"
    function isTimestampsValid() {
      return (!request.resource.data.keys().hasAll(['createdAt']) || request.resource.data.createdAt == request.time)
          && (!request.resource.data.keys().hasAll(['updatedAt']) || request.resource.data.updatedAt == request.time);
    }

    // ─── USER COLLECTIONS ─────────────────────────────────
    
    match /users/{userId} {
      // Users can only read/write their own profile
      allow read: if isOwner(userId) || isAdmin();
      
      // On creation, stricter validation could be applied here
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow update: if isOwner(userId) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledBatches'])
      );

      // ─── Subcollections ───

      // Stats: Publicly readable for leaderboards? 
      // For now, keep private or allow authenticated read if building a leaderboard
      match /stats/{document=**} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
      
      // Private Data (Syllabus, Docs, Tests)
      match /syllabus/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /docs/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /tests/{testId} {
        allow read, write: if isOwner(userId);
      }
      match /test_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
        
        match /events/{eventId} {
          allow read, write: if isOwner(userId);
        }
      }
      match /flashcards/{flashcardId} {
        allow read, write: if isOwner(userId);
      }
      match /saved_articles/{articleId} {
        allow read, write: if isOwner(userId);
      }
      match /api_usage/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId); // Rate limiting logic should ideally be server-side
      }
    }

    // ─── INSTITUTION COLLECTIONS ──────────────────────────

    match /institutions/{instId} {
      // Only the institution owner can write
      allow write: if isOwner(instId);
      
      // Institution profile might need to be public for students to join?
      allow read: if isAuthenticated(); 
      
      match /students/{studentId} {
        // Institution can read their students
        allow read: if isOwner(instId) || request.auth.uid == studentId;
        // Logic for joining uses Cloud Functions or specific requests usually
        allow write: if isOwner(instId); 
      }
      
      match /tests/{testId} {
        allow read: if isAuthenticated(); // Students need to take tests
        allow write: if isOwner(instId);
      }
    }

    // ─── SHARED / GLOBAL COLLECTIONS ──────────────────────

    // Leaderboards (Aggregation)
    match /leaderboards/{period} {
      allow read: if isAuthenticated();
      allow write: if false; // Only updated by server
    }

    // Cached Tests (Performance/Scalability)
    match /cached_tests/{testId} {
      allow read: if isAuthenticated();
      // Allow creation by authenticated users (AI generation)
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // Contact Form
    match /contact_submissions/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Admins
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // Server-only (Private)
    match /_test_questions/{testId} {
        allow read, write: if false;
    }
    // ─── Institution Tests ──────────────────────────────
    match /institution_tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.creatorId);
    }

    // ─── Institution Batches ────────────────────────────
    match /institution_batches/{batchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.creatorId);

      match /members/{memberId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(get(/databases/$(database)/documents/institution_batches/$(batchId)).data.creatorId);
      }
    }
  }
}
